# Database
DATABASE_URL=postgresql://oneconnect:oneconnect_secret@localhost:5432/oneconnect_db?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# AWS S3 (Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name
# Optional: CDN/custom domain base URL (without trailing slash)
# AWS_S3_PUBLIC_BASE_URL=https://cdn.your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=15
